---
import Layout from "./Layout.astro";
---

<Layout title="IITM BS: Multi-Stream Hub">
    <div class="w-full min-h-screen bg-[#fafafa] text-black flex items-center justify-center p-4 sm:p-8 relative overflow-hidden select-none">
        
        <div class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center opacity-[0.80]">
            <img 
                src="/image.png" 
                alt="" 
                class="w-full h-full object-cover scale-105"
            />
        </div>

        <div class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center opacity-30 mix-blend-multiply">
            <div class="w-[800px] h-[800px] border-dashed border-4 border-fuchsia-500 rounded-full animate-[spin_20s_linear_infinite] absolute"></div>
            <div class="w-[600px] h-[600px] border-double border-8 border-cyan-400 rounded-full animate-[spin_12s_linear_infinite_reverse] absolute"></div>
        </div>

        <div class="absolute inset-0 z-10 pointer-events-none text-[10px] text-zinc-600 space-y-2">
            <div class="absolute top-[10%] left-[5%] rotate-12 bg-white border-2 border-black p-1 font-mono">&lt;HTML&gt;<br/>&lt;div class="Never gonna run around and desert you"&gt;</div>
            <div class="absolute bottom-[20%] left-[8%] -rotate-12 bg-white border-2 border-black p-2 text-fuchsia-600 font-mono">class="never gonna let you down"</div>
            <div class="absolute top-[15%] right-[12%] rotate-[45deg] bg-white border-2 border-black p-1 text-cyan-600 font-mono">Never gonna make you cry</div>
            <div class="absolute bottom-[15%] right-[5%] -rotate-[30deg] border-t-2 border-dashed border-black w-40"></div>
            <div class="absolute top-[50%] left-[2%] text-xs text-zinc-500 tracking-widest font-mono">[NEVER_GONNA_GIVE_YOU_UP]</div>
        </div>

        <div class="w-full max-w-2xl bg-white border-[4px] border-black rounded-none p-8 sm:p-12 flex flex-col items-center justify-center gap-12 relative z-20 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all">
            
            <div class="absolute -top-3 -left-3 text-2xl select-none text-black">✦</div>
            <div class="absolute -bottom-5 -right-3 text-2xl select-none text-black">✦</div>

            <div class="relative w-full text-center">
                <h1 class="text-3xl sm:text-5xl font-black uppercase tracking-tighter relative inline-block text-black font-mono leading-none pt-2">
                    <span class="absolute top-0 left-0 -translate-x-[2px] -translate-y-[2px] text-fuchsia-500 opacity-40">IITM BS:<br />Multi-Stream Hub</span>
                    <span class="absolute top-0 left-0 translate-x-[2px] translate-y-[2px] text-cyan-400 opacity-40">IITM BS:<br />Multi-Stream Hub</span>
                    <span class="relative">IITM BS:<br />Multi-Stream Hub</span>
                </h1>
            </div>

            <div class="w-full max-w-sm flex flex-col sm:flex-row items-center justify-center gap-6 relative">
            
                <div class="relative group w-full sm:w-1/2 transform -rotate-2 hover:rotate-0 transition-transform duration-150">
                    <div class="absolute inset-0 bg-cyan-400 translate-x-1.5 translate-y-1.5 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-200 border-2 border-black"></div>
                    <a 
                        href="https://discord.com/app" 
                        class="relative block w-full py-3.5 px-4 bg-white text-black border-2 border-black font-black text-lg text-center uppercase tracking-wider active:translate-x-0.5 active:translate-y-0.5 transition-colors group-hover:bg-yellow-100"
                    >
                        Discord
                    </a>
                </div>

                <div class="relative group w-full sm:w-1/2 transform rotate-3 hover:rotate-0 transition-transform duration-150">
                    <div class="absolute inset-0 bg-fuchsia-500 -translate-x-1.5 translate-y-1.5 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-200 border-2 border-black"></div>
                    <a 
                        href="/github" 
                        class="relative block w-full py-3.5 px-4 bg-black text-white border-2 border-black font-black text-lg text-center uppercase tracking-wider active:translate-x-0.5 active:translate-y-0.5 transition-colors group-hover:bg-zinc-900"
                    >
                        GitHub
                    </a>
                </div>

            </div>

            <div class="w-full text-center mt-2 border-t border-dashed border-black/20 pt-6">
                <div class="text-[10px] tracking-[0.3em] text-zinc-500 uppercase font-mono">
                	 █▄ ▄█ ▄▀▄ █▀▄ █▀▀ <br class="sm:hidden" /> █ █ █ █▀█ █▄▀ ██▄ 
                </div>
                <div class="text-sm mt-3 text-black font-black tracking-widest font-mono">
                    Made with tears by <span class="bg-yellow-400 border border-black text-black px-1.5 py-0.5 line-through decoration-black decoration-2">Auster</span>
                </div>
            </div>

        </div>
        
        <div class="absolute bottom-0 left-0 right-0 h-4 bg-gradient-to-r from-purple-600 via-pink-500 to-cyan-400 opacity-60 mix-blend-difference"></div>
        <div class="absolute top-0 left-0 w-4 h-full bg-gradient-to-b from-purple-600 via-transparent to-cyan-400 opacity-10"></div>
    </div>
</Layout>