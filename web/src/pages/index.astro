---
import Layout from "./Layout.astro";

const params = Astro.url.searchParams;
const isSurpriseActive = params.has("surprise");
---

<Layout title="IITM BS: Multi-Stream Hub">
    <div class="w-full min-h-screen bg-[#f4f4f0] text-[#1c1c1a] flex items-center justify-center p-6 sm:p-12 relative overflow-hidden select-none">
        
        <div class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center opacity-[0.60]">
            <img 
                src="/image.png" 
                alt="" 
                class="w-full h-full object-cover scale-105 filter grayscale sepia-[10%]"
            />
        </div>

        <div class="w-full max-w-3xl bg-[#fafaf7] border-[4px] border-[#1c1c1a] rounded-none p-10 sm:p-16 flex flex-col items-center justify-center gap-14 relative z-20 shadow-[10px_10px_0px_0px_rgba(28,28,26,1)] transition-all">
            
            <div class="absolute -top-4 -left-4 text-3xl select-none text-[#1c1c1a]">✦</div>
            <div class="absolute -bottom-6 -right-4 text-3xl select-none text-[#1c1c1a]">✦</div>

            {
                isSurpriseActive ? (
                    <div id="surprise-container" class="w-full flex flex-col items-center text-center space-y-8 py-6">
                        <div class="space-y-4">
                            <h1 class="text-4xl sm:text-6xl font-black uppercase tracking-tight text-[#1c1c1a]">
                                Surprising you...
                            </h1>
                            <p class="text-lg sm:text-xl text-[#3a3a37] font-mono font-medium">
                                Just hold on for <span id="countdown" class="underline decoration-wavy font-bold text-2xl">3</span> seconds.
                            </p>
                        </div>
                    </div>
                ) : (
                    <>
                        <div class="relative w-full text-center">
                            <h1 class="text-4xl sm:text-6xl font-black uppercase tracking-tight relative inline-block text-[#1c1c1a] font-mono leading-none pt-2">
                                <span class="absolute top-0 left-0 -translate-x-[2px] -translate-y-[2px] text-zinc-300 opacity-60">IITM BS:<br />Multi-Stream Hub</span>
                                <span class="absolute top-0 left-0 translate-x-[2px] translate-y-[2px] text-zinc-400 opacity-30">IITM BS:<br />Multi-Stream Hub</span>
                                <span class="relative">IITM BS:<br />Multi-Stream Hub</span>
                            </h1>
                        </div>

                        <div class="w-full max-w-md flex flex-col items-stretch gap-6 relative">
                            <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
                                <div class="relative group w-full sm:w-1/2 transform -rotate-2 hover:rotate-0 transition-transform duration-150">
                                    <div class="absolute inset-0 bg-[#1c1c1a] translate-x-1.5 translate-y-1.5 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-200 border-2 border-[#1c1c1a]"></div>
                                    <a 
                                        href="https://discord.com/app" 
                                        class="relative block w-full reply-btn py-4 px-4 bg-white text-[#1c1c1a] border-4 border-[#1c1c1a] font-black text-xl text-center uppercase tracking-wider active:translate-x-0.5 active:translate-y-0.5 transition-colors hover:bg-amber-50"
                                    >
                                        Discord
                                    </a>
                                </div>

                                <div class="relative group w-full sm:w-1/2 transform rotate-3 hover:rotate-0 transition-transform duration-150">
                                    <div class="absolute inset-0 bg-[#5e5e5a] -translate-x-1.5 translate-y-1.5 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-200 border-2 border-[#1c1c1a]"></div>
                                    <a 
                                        href="/github" 
                                        class="relative block w-full py-4 px-4 bg-[#1c1c1a] text-white border-4 border-[#1c1c1a] font-black text-xl text-center uppercase tracking-wider active:translate-x-0.5 active:translate-y-0.5 transition-colors hover:bg-zinc-800"
                                    >
                                        GitHub
                                    </a>
                                </div>
                            </div>

                            <div class="relative group w-full pt-2">
                                <div class="absolute inset-0 bg-amber-400 translate-x-1 translate-y-1 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform duration-200 border-2 border-[#1c1c1a]"></div>
                                <a 
                                    href="?surprise=true"
                                    class="relative block w-full py-4 px-6 bg-[#ffffff] text-[#1c1c1a] border-4 border-[#1c1c1a] font-black text-lg sm:text-xl text-center uppercase tracking-widest active:translate-x-0.5 active:translate-y-0.5 transition-all hover:bg-amber-50"
                                >
                                    ✦ Surprise me ✦
                                </a>
                            </div>
                        </div>

                        <div class="w-full text-center mt-2 border-t-4 border-dashed border-[#1c1c1a]/20 pt-8">
                            <div class="text-xs tracking-[0.3em] text-zinc-500 uppercase font-mono mb-2">
                                █▄ ▄█ ▄▀▄ █▀▄ █▀▀ █ █ █ █▀█ █▄▀ ██▄
                            </div>
                            <div class="text-base mt-4 text-[#1c1c1a] font-black tracking-widest font-mono">
                                Made with tears by <span class="bg-amber-300 border-2 border-[#1c1c1a] text-[#1c1c1a] px-2 py-0.5 line-through decoration-[#1c1c1a] decoration-2">Auster</span>
                            </div>
                        </div>
                    </>
                )
            }
        </div>
    </div>
</Layout>

<script>
    const params = new URLSearchParams(window.location.search);
    if (params.has('surprise')) {
        let seconds = 3;
        const countdownEl = document.getElementById('countdown');
        
        const interval = setInterval(() => {
            seconds--;
            if (countdownEl) countdownEl.textContent = seconds.toString();
            
            if (seconds <= 0) {
                clearInterval(interval);
                window.location.href = "https://www.youtube.com/watch?v=dQw4w9WgXcQ";
            }
        }, 1000);
    }
</script>