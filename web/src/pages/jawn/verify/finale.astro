---
import Layout from "../../Layout.astro";

const params = Astro.url.searchParams;

const hasParams = params.has("verified");
const isVerified = params.get("verified") === "true";
const degreeName = (params.get("degree_type") || "N/A").toUpperCase();
const userIdString = params.get("user_id") || "Unknown";
const errorReason = params.get("reason") || "";
---
<Layout title={isVerified ? "Success" : "Failure"}>
    <div
        class="w-full min-h-screen bg-[#f4f4f0] text-[#1c1c1a] flex items-center justify-center p-6 sm:p-12 antialiased font-mono relative overflow-hidden"
    >
        <div
            class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center opacity-[0.60]"
        >
            <img
                src="/image.png"
                alt=""
                class="w-full h-full object-cover scale-105 filter grayscale sepia-[10%]"
            />
        </div>

        <div
            class="w-full max-w-3xl bg-[#fafaf7] border-[4px] border-[#1c1c1a] rounded-none p-10 sm:p-16 flex flex-col items-center justify-center relative z-10 shadow-[10px_10px_0px_0px_rgba(28,28,26,1)] transition-all"
        >
            <div class="absolute -top-4 -left-4 text-3xl select-none text-[#1c1c1a]">✦</div>
            <div class="absolute -bottom-6 -right-4 text-3xl select-none text-[#1c1c1a]">
                ✦
            </div>

            {
                !hasParams ? (
                    <div class="w-full flex flex-col items-stretch text-left space-y-10">
                        <div class="border-4 border-[#1c1c1a] bg-[#fdfdf7] p-8 sm:p-10 relative shadow-[8px_8px_0px_0px_rgba(28,28,26,1)] flex flex-col sm:flex-row items-start gap-8">
                            <div class="absolute -top-4 left-6 bg-amber-500 text-black border-2 border-[#1c1c1a] text-xs sm:text-sm font-black uppercase tracking-widest px-3 py-1">
                                Missing context configuration
                            </div>

                            <div class="flex-shrink-0 w-16 h-16 bg-[#1c1c1a] flex items-center justify-center relative select-none mt-4 sm:mt-0">
                                <div class="absolute inset-0 border border-white m-1" />
                                <span class="text-white font-mono font-black text-2xl">
                                    ?
                                </span>
                            </div>

                            <div class="space-y-3 flex-1 pt-2">
                                <h1 class="text-3xl sm:text-4xl font-black uppercase tracking-tight text-[#1c1c1a]">
                                    Malformed Session
                                </h1>
                                <p class="text-base sm:text-lg text-[#3a3a37] leading-relaxed font-mono font-medium">
                                    Session state parameters are missing or corrupted.
                                    Please return to Discord and try again.
                                </p>
                            </div>
                        </div>

                        <div class="flex flex-col sm:flex-row gap-4 w-full pt-4">
                            <a
                                href="https://discord.com/app"
                                class="flex-1 border-4 border-[#1c1c1a] py-5 px-6 text-base sm:text-xl font-black text-[#1c1c1a] bg-white hover:bg-[#1c1c1a] hover:text-white text-center transition-all uppercase tracking-wider shadow-[6px_6px_0px_0px_rgba(28,28,26,1)] active:translate-x-1 active:translate-y-1 active:shadow-[2px_2px_0px_0px_rgba(28,28,26,1)]"
                            >
                                [ Return to Discord ]
                            </a>
                        </div>
                    </div>
                ) : isVerified ? (
                    <div class="w-full flex flex-col items-center text-center space-y-8">
                        <div class="space-y-4">
                            <h1 class="text-4xl sm:text-5xl font-black uppercase tracking-tighter leading-tight text-[#1c1c1a]">
                                Welcome to
                                <br />
                                <span class="text-cyan-800 opacity-90">
                                    IITM BS: Multi-Stream Hub
                                </span>
                            </h1>
                            <p class="text-lg sm:text-xl text-[#3a3a37] max-w-xl mx-auto leading-relaxed font-semibold">
                                Your student email has been verified. You will
                                receive a confirmation message on Discord
                                shortly.
                            </p>
                        </div>

                        <div class="w-full max-w-md grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4">
                            <button
                                id="copy-btn"
                                data-id={userIdString}
                                class="border-4 border-[#1c1c1a] bg-[#ffffff] p-6 hover:bg-amber-50 active:translate-x-1 active:translate-y-1 transition-all flex flex-col items-center justify-center gap-2 group shadow-[6px_6px_0px_0px_rgba(28,28,26,1)] active:shadow-[2px_2px_0px_0px_rgba(28,28,26,1)]"
                            >
                                <span class="text-xs font-black tracking-widest text-gray-400 uppercase font-mono">
                                    DISCORD ID
                                </span>
                                <span
                                    id="btn-text"
                                    class="text-base sm:text-lg font-bold text-[#1c1c1a] break-all font-mono tracking-tight underline decoration-dotted"
                                >
                                    {userIdString.length > 12
                                        ? userIdString.substring(0, 12) + "..."
                                        : userIdString}
                                </span>
                            </button>

                            <div class="border-4 border-[#1c1c1a] bg-[#ffffff] p-6 flex flex-col items-center justify-center gap-1 shadow-[6px_6px_0px_0px_rgba(28,28,26,1)]">
                                <span class="text-xs font-black tracking-widest text-gray-400 uppercase font-mono">
                                    DEGREE
                                </span>
                                <span class="text-2xl sm:text-3xl font-black text-[#1c1c1a] tracking-tight font-mono">
                                    {degreeName}
                                </span>
                            </div>
                        </div>

                        <a
                            href="https://discord.com/app"
                            class="w-full max-w-md border-4 border-[#1c1c1a] py-5 px-6 text-base sm:text-xl font-black text-white bg-[#1c1c1a] hover:bg-amber-400 hover:text-black text-center transition-colors uppercase tracking-widest shadow-[6px_6px_0px_0px_rgba(28,28,26,1)] active:translate-x-1 active:translate-y-1 active:shadow-[2px_2px_0px_0px_rgba(28,28,26,1)]"
                        >
                            Go back to Discord
                        </a>
                    </div>
                ) : (
                    <div class="w-full flex flex-col items-stretch text-left space-y-10">
                        <div class="border-4 border-[#1c1c1a] bg-[#fdfdf7] p-8 sm:p-10 relative shadow-[8px_8px_0px_0px_rgba(28,28,26,1)] flex flex-col sm:flex-row items-start gap-8">
                            <div class="absolute -top-4 left-6 bg-red-600 text-white border-2 border-[#1c1c1a] text-xs sm:text-sm font-black uppercase tracking-widest px-3 py-1">
                                {userIdString}
                            </div>

                            <div class="flex-shrink-0 w-16 h-16 bg-[#1c1c1a] flex items-center justify-center relative select-none mt-4 sm:mt-0">
                                <div class="absolute inset-0 border border-white m-1" />
                                <span class="text-white font-mono font-black text-2xl">
                                    !
                                </span>
                            </div>

                            <div class="space-y-3 flex-1 pt-2">
                                <h1 class="text-3xl sm:text-4xl font-black uppercase tracking-tight text-[#1c1c1a]">
                                    Rejected!
                                </h1>
                                <p class="text-base sm:text-lg text-[#3a3a37] leading-relaxed font-mono font-medium">
                                    {errorReason ||
                                        "Your student email is not assigned by IIT Madras. Please use your authorized student email address."}
                                </p>
                            </div>
                        </div>

                        <div class="flex flex-col sm:flex-row gap-6 w-full pt-4">
                            <a
                                href="https://discord.com/app"
                                class="flex-1 border-4 border-[#1c1c1a] py-5 px-6 text-base sm:text-xl font-black text-[#1c1c1a] bg-white hover:bg-[#1c1c1a] hover:text-white text-center transition-all uppercase tracking-wider shadow-[6px_6px_0px_0px_rgba(28,28,26,1)] active:translate-x-1 active:translate-y-1 active:shadow-[2px_2px_0px_0px_rgba(28,28,26,1)]"
                            >
                                [ Retry Authentication ]
                            </a>
                            <a
                                href="https://study.iitm.ac.in/es/faq.html"
                                class="flex-1 border-4 border-[#1c1c1a] py-5 px-6 text-base sm:text-xl font-black text-[#5e5e5a] bg-[#f4f4f0] hover:bg-[#1c1c1a] hover:text-white text-center transition-all uppercase tracking-wider shadow-[6px_6px_0px_0px_rgba(28,28,26,1)] active:translate-x-1 active:translate-y-1 active:shadow-[2px_2px_0px_0px_rgba(28,28,26,1)]"
                            >
                                View FAQ Page
                            </a>
                        </div>
                    </div>
                )
            }
        </div>
    </div>
</Layout>

<script>
    const copyBtn = document.getElementById('copy-btn');
    const btnText = document.getElementById('btn-text');

    if (copyBtn && btnText) {
        const rawId = copyBtn.getAttribute('data-id') || '';
        const originalText = btnText.innerText;

        copyBtn.addEventListener('click', async () => {
            try {
                await navigator.clipboard.writeText(rawId);
                btnText.innerText = "COPIED!";
                btnText.style.color = "#047857";
                
                setTimeout(() => {
                    btnText.innerText = originalText;
                    btnText.style.color = "";
                }, 1200);
            } catch (err) {
                console.error(err);
            }
        });
    }
</script>