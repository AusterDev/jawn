---
import type { VerificationResult } from "../../../types";
import Layout from "../../Layout.astro";

const { cookies } = Astro;

let result: VerificationResult | null = null;
let parseError = false;

try {
    const cookieData = cookies.get("result");
    if (cookieData) {
        result = cookieData.json() as VerificationResult;
    }
} catch (e) {
    console.error(e);
    parseError = true;
}

const isVerified = result?.verified ?? false;
const degreeName = result?.degreeType ? result.degreeType.toUpperCase() : "N/A";
---
<Layout title={isVerified ? "Success" : "Failure"}>
    <div
        class="w-full min-h-screen bg-[#fafafa] text-black flex items-center justify-center p-4 sm:p-8 antialiased font-mono relative overflow-hidden"
    >
        <div
            class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center opacity-[0.80]"
        >
            <img
                src="/image.png"
                alt=""
                class="w-full h-full object-cover scale-105"
            />
        </div>

        <div
            class="w-full max-w-2xl bg-white border-[4px] border-black rounded-none p-8 sm:p-12 flex flex-col items-center justify-center relative z-10 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all"
        >
            <div class="absolute -top-3 -left-3 text-2xl select-none">✦</div>
            <div class="absolute -bottom-5 -right-3 text-2xl select-none">
                ✦
            </div>

            {
                parseError || !result ? (
                    <div class="w-full flex flex-col items-stretch text-left space-y-8">
                        <div class="border-4 border-black bg-yellow-50 p-6 sm:p-8 relative shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] flex flex-col sm:flex-row items-start gap-6">
                            <div class="absolute -top-3.5 left-4 bg-yellow-500 text-black border-2 border-black text-[10px] font-black uppercase tracking-widest px-2 py-0.5">
                                Missing essential cookies
                            </div>

                            <div class="flex-shrink-0 w-12 h-12 bg-black flex items-center justify-center relative select-none mt-2 sm:mt-0">
                                <div class="absolute inset-0 border border-white m-1" />
                                <span class="text-white font-mono font-black text-xl">
                                    ?
                                </span>
                            </div>

                            <div class="space-y-2 flex-1">
                                <h1 class="text-2xl sm:text-3xl font-black uppercase tracking-tight text-black">
                                    Malformed Session
                                </h1>
                                <p class="text-xs sm:text-sm text-gray-800 leading-relaxed font-mono font-medium">
                                    Session state is missing or corrupted.
                                    Please return to discord and try again.
                                </p>
                            </div>
                        </div>

                        <div class="flex flex-col sm:flex-row gap-4 w-full pt-2">
                            <a
                                href="https://discord.com/app"
                                class="flex-1 border-2 border-black py-3.5 px-4 text-xs sm:text-sm font-black text-black bg-white hover:bg-black hover:text-white text-center transition-all uppercase tracking-wider shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:translate-x-0.5 active:translate-y-0.5"
                            >
                                [ Return to Discord ]
                            </a>
                        </div>
                    </div>
                ) : isVerified ? (
                    <div class="w-full flex flex-col items-center text-center space-y-6">
                        <div class="inline-block bg-emerald-100 border-2 border-black text-emerald-700 font-black text-lg px-3 py-1 uppercase tracking-widest">
                            Access Granted
                        </div>

                        <div class="space-y-3">
                            <h1 class="text-3xl sm:text-4xl font-black uppercase tracking-tighter leading-tight">
                                Welcome to
                                <span class="text-cyan-700 opacity-40 shadow-cyan-500 shadow-lg">
                                    IITM BS:
                                    <br />
                                    Multi-Stream Hub
                                </span>
                            </h1>
                            <p class="text-sm sm:text-lg text-gray-700 max-w-md mx-auto leading-relaxed font-semibold">
                                Your student email has been verified, you will
                                receive a confirmation message on Discord
                                shortly.
                            </p>
                        </div>

                        <div class="w-full max-w-sm grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
                            <button
                                id="copy-btn"
                                data-id={result.userID}
                                class="border-2 border-black bg-gray-50 p-4 hover:bg-yellow-100 active:translate-x-0.5 active:translate-y-0.5 transition-all flex flex-col items-center justify-center gap-1 group shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none"
                            >
                                <span class="text-[10px] font-black tracking-widest text-gray-400 uppercase font-mono">
                                    DISCORD ID
                                </span>
                                <span
                                    id="btn-text"
                                    class="text-xs sm:text-sm font-bold text-black break-all font-mono tracking-tight"
                                >
                                    {result.userID.length > 12
                                        ? result.userID.substring(0, 12) + "..."
                                        : result.userID}
                                </span>
                            </button>

                            <div class="border-2 border-black bg-gray-50 p-4 flex flex-col items-center justify-center gap-0.5 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                                <span class="text-[10px] font-black tracking-widest text-gray-400 uppercase font-mono">
                                    DEGREE
                                </span>
                                <span class="text-xl font-black text-black tracking-tight font-mono">
                                    {degreeName}
                                </span>
                            </div>
                        </div>

                        <a
                            href="https://discord.com"
                            class="w-full max-w-sm border-2 border-black py-3 px-6 text-sm font-black text-white bg-black hover:bg-yellow-400 hover:text-black text-center transition-colors uppercase tracking-widest shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:translate-x-0.5 active:translate-y-0.5"
                        >
                            Go back to Discord
                        </a>
                    </div>
                ) : (
                    <div class="w-full flex flex-col items-stretch text-left space-y-8">
                        <div class="border-4 border-black bg-red-50 p-6 sm:p-8 relative shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] flex flex-col sm:flex-row items-start gap-6">
                            <div class="absolute -top-3.5 left-4 bg-red-600 text-white border-2 border-black text-[10px] font-black uppercase tracking-widest px-2 py-0.5">
                                {result.userID}
                            </div>

                            <div class="flex-shrink-0 w-12 h-12 bg-black flex items-center justify-center relative select-none mt-2 sm:mt-0">
                                <div class="absolute inset-0 border border-white m-1" />
                                <span class="text-white font-mono font-black text-xl">
                                    !
                                </span>
                            </div>

                            <div class="space-y-2 flex-1">
                                <h1 class="text-2xl sm:text-3xl font-black uppercase tracking-tight text-black">
                                    Access Rejected
                                </h1>
                                <p class="text-xs sm:text-sm text-gray-800 leading-relaxed font-mono font-medium">
                                    {result.reason ||
                                        "Your student email is not assigned by IIT Madras. Please use your authorized student email address."}
                                </p>
                            </div>
                        </div>

                        <div class="flex flex-col sm:flex-row gap-4 w-full pt-2">
                            <a
                                href="https://discord.com/app"
                                class="flex-1 border-2 border-black py-3.5 px-4 text-xs sm:text-sm font-black text-black bg-white hover:bg-black hover:text-white text-center transition-all uppercase tracking-wider shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:translate-x-0.5 active:translate-y-0.5"
                            >
                                [ Retry Authentication ]
                            </a>
                            <a
                                href="https://study.iitm.ac.in/es/faq.html"
                                class="flex-1 border-2 border-black py-3.5 px-4 text-xs sm:text-sm font-black text-gray-500 bg-gray-50 hover:bg-black hover:text-white text-center transition-all uppercase tracking-wider shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:translate-x-0.5 active:translate-y-0.5"
                            >
                                View FAQ Page
                            </a>
                        </div>
                    </div>
                )
            }
        </div>
    </div>
</Layout>

<script>
    const copyBtn = document.getElementById('copy-btn');
    const btnText = document.getElementById('btn-text');

    if (copyBtn && btnText) {
        const rawId = copyBtn.getAttribute('data-id') || '';
        const originalText = btnText.innerText;

        copyBtn.addEventListener('click', async () => {
            try {
                await navigator.clipboard.writeText(rawId);
                btnText.innerText = "COPIED!";
                btnText.style.color = "#10b981";
                
                setTimeout(() => {
                    btnText.innerText = originalText;
                    btnText.style.color = "";
                }, 1200);
            } catch (err) {
                console.error(err);
            }
        });
    }
</script>