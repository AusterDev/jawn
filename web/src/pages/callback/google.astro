---
import RedisClient from "../../lib/redis";
import Layout from "../Layout.astro";
import { buildOAuth2Url } from "../../lib/discord.auth";

const params = Astro.url.searchParams;
const code = params.get("code");
const sessionID = params.get("state");

const fallbackUrl = "/jawn/verify/finale";

if (!code || !sessionID) {
    return Astro.redirect(fallbackUrl);
}

let email = "";
let isAllowed = false;
let degreeEnum: "DS" | "ES" | "AES" | "NONE" = "NONE";
let discorduser_id = "";

try {
    const redisKey = `session:${sessionID}`;
    const rawSession = await RedisClient.get(redisKey);

    if (!rawSession) {
        console.error("Session missing or expired in Redis");
        return Astro.redirect(fallbackUrl);
    }

    const session = JSON.parse(rawSession);
    discorduser_id = session.user_id; 

    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 8000);

    const tokenResponse = await fetch("https://oauth2.googleapis.com/token", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        signal: controller.signal,
        body: new URLSearchParams({
            code,
            client_id: process.env.GOOGLE_CLIENT_ID || "",
            client_secret: process.env.GOOGLE_CLIENT_SECRET || "",
            redirect_uri: `${process.env.WEB_HOST}/callback/google`,
            grant_type: "authorization_code",
        }),
    });
    clearTimeout(timeoutId);

    if (!tokenResponse.ok) {
        return Astro.redirect(fallbackUrl);
    }

    const tokens = await tokenResponse.json();

    const profileResponse = await fetch("https://www.googleapis.com/oauth2/v2/userinfo", {
        headers: { Authorization: `Bearer ${tokens.access_token}` },
    });

    if (!profileResponse.ok) {
        return Astro.redirect(fallbackUrl);
    }

    const profile = await profileResponse.json();
    email = profile.email ? profile.email.toLowerCase().trim() : "";

    const ALLOWED_DEGREES = ["ds", "es", "aes"] as const;
    const match = email.match(/^[^@]+@([^.]+)\.study\.iitm\.ac\.in$/);
    
    if (match) {
        const subdomain = match[1];
        if ((ALLOWED_DEGREES as readonly string[]).includes(subdomain)) {
            isAllowed = true;
            degreeEnum = subdomain.toUpperCase() as "DS" | "ES" | "AES";
        }
    }

    if (!isAllowed) {
        degreeEnum = "NONE";
    }

    const authSessionData = {
        sessionID,
        discord_user_id: discorduser_id,
        email,
        is_allowed: isAllowed,
        degree: degreeEnum,
    };

    await RedisClient.setex(`auth_session:${sessionID}`, 300, JSON.stringify(authSessionData));

} catch (error) {
    console.error("Verification step failed:", error);
    return Astro.redirect(fallbackUrl);
}

const discordAuthUrl = buildOAuth2Url(sessionID);
---

<Layout>
    <head>
        <meta http-equiv="refresh" content={`5;url=${discordAuthUrl}`} />
    </head>

    <div
        class="w-full min-h-screen bg-[#f4f4f0] text-[#1c1c1a] flex items-center justify-center p-6 sm:p-12 antialiased font-mono relative overflow-hidden"
    >
        <div
            class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center opacity-[0.60]"
        >
            <img
                src="/image.png"
                alt=""
                class="w-full h-full object-cover scale-105 filter grayscale sepia-[10%]"
            />
        </div>

        <div
            class="w-full max-w-3xl bg-[#fafaf7] border-[4px] border-[#1c1c1a] rounded-none p-10 sm:p-16 flex flex-col items-center justify-center relative z-10 shadow-[10px_10px_0px_0px_rgba(28,28,26,1)] transition-all"
        >
            <div class="absolute -top-4 -left-4 text-3xl select-none text-[#1c1c1a]">✦</div>
            <div class="absolute -bottom-6 -right-4 text-3xl select-none text-[#1c1c1a]">
                ✦
            </div>

            <div class="w-full flex flex-col items-stretch text-left space-y-10">
                <div class="border-4 border-[#1c1c1a] bg-[#fdfdfb] p-8 sm:p-10 relative shadow-[8px_8px_0px_0px_rgba(28,28,26,1)] flex flex-col items-start gap-8">
                    <div class="absolute -top-4 left-6 bg-[#1c1c1a] text-white border-2 border-[#1c1c1a] text-xs sm:text-sm font-black uppercase tracking-widest px-3 py-1">
                        Email: {email || "Verifying..."}
                    </div>

                    <div class="space-y-4 flex-1 pt-2">
                        <h1 class="text-3xl sm:text-5xl font-black uppercase tracking-tight text-[#1c1c1a]">
                            Who are you?
                        </h1>
                        <p class="text-lg sm:text-xl text-[#3a3a37] leading-relaxed font-mono font-medium">
                            Authenticate using your Discord account ID to make sure you didn't steal the session state from someone else.
                        </p>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row gap-4 w-full pt-4">
                    <a
                        href={discordAuthUrl}
                        class="flex-1 border-4 border-[#1c1c1a] py-5 px-6 text-base sm:text-xl font-black text-[#1c1c1a] bg-[#ffffff] text-center transition-all uppercase tracking-wider shadow-[6px_6px_0px_0px_rgba(28,28,26,1)] hover:bg-[#f4f4f0] active:translate-x-1 active:translate-y-1 active:shadow-[2px_2px_0px_0px_rgba(28,28,26,1)]"
                    >
                        Redirecting in <span id="countdown" class="underline decoration-wavy">5</span> seconds... or click here
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script define:vars={{ discordAuthUrl }}>
        let seconds = 5;
        const countdownEl = document.getElementById("countdown");
        
        const interval = setInterval(() => {
            seconds--;
            if (countdownEl) countdownEl.textContent = seconds;
            if (seconds <= 0) {
                clearInterval(interval);
                window.location.href = discordAuthUrl;
            }
        }, 1000);
    </script>
</Layout>